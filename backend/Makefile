install:
	npm install

dev:
	npm run dev

test:
	npm test

lint:
	npm run lint

build:
	npm run build

up:
	docker compose up --build

down:
	docker compose down

migrate:
	npm run migrate

seed:
	npm run seed

valhalla-build:
	npm run valhalla:build

valhalla-package:
	npm run valhalla:package

osm-refresh:
	npm run osm:refresh

raspberry-smoke:
	npm run raspberry:smoke

health:
	npm run health
