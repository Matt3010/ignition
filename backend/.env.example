NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://road:road@postgres:5432/road_context
VALHALLA_BASE_URL=http://valhalla:8002
ROAD_CONTEXT_PROVIDER=valhalla
REQUEST_TIMEOUT_MS=5000
VALHALLA_TIMEOUT_MS=2500
MAX_GPS_ACCURACY_METERS=50
ALERT_SEARCH_RADIUS_METERS=1500
ALERT_BEHIND_MIN_ANGLE_DEGREES=135
ALERT_BEHIND_IMMEDIATE_ANGLE_DEGREES=170
ALERT_BEHIND_MIN_SPEED_KMH=5
ALERT_BEHIND_MAX_GPS_ACCURACY_METERS=25
ALERT_BEHIND_MIN_DISTANCE_INCREASE_METERS=5
SESSION_TRACE_TTL_SECONDS=180
LOG_LEVEL=info
CORS_ORIGIN=*
PAYLOAD_LIMIT_BYTES=65536
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute
MIN_CLIENT_INTERVAL_MS=1000
API_VERSION=1.0.0
APP_DEBUG_LOG_DIR=./reports/app-debug-logs
OSM_EXTRACT_PRESET=italy
OSM_EXTRACT_URL=
OSM_REGION=italy
OSM_DATA_DIR=./data/osm
OSM_HOST_DATA_DIR=
VALHALLA_TILE_DIR=./data/valhalla
OSM_REFRESH_INTERVAL_SECONDS=86400
OSM_REFRESH_RUN_ON_START=false
OSM_REFRESH_RESTART_VALHALLA=true
OSM_REFRESH_IMPORT_ALERTS=true
OSM_REFRESH_LOCK_TIMEOUT_SECONDS=3600
