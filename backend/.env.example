NODE_ENV=development
PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://road:road@postgres:5432/road_context
VALHALLA_BASE_URL=http://valhalla:8002
ROAD_CONTEXT_PROVIDER=valhalla
REQUEST_TIMEOUT_MS=5000
VALHALLA_TIMEOUT_MS=2500
MAX_GPS_ACCURACY_METERS=50
ALERT_SEARCH_RADIUS_METERS=1500
ALERT_DIRECTION_TOLERANCE_DEGREES=45
SESSION_TRACE_TTL_SECONDS=180
CACHE_TTL_SECONDS=5
LOG_LEVEL=info
CORS_ORIGIN=*
PAYLOAD_LIMIT_BYTES=65536
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute
MIN_CLIENT_INTERVAL_MS=1000
API_VERSION=1.0.0
APP_DEBUG_LOG_DIR=./reports/app-debug-logs
OSM_REGION=prefetch
OSM_DATA_DIR=./data/osm
OSM_HOST_DATA_DIR=
OSM_BBOX=
VALHALLA_TILE_DIR=./data/valhalla
VALHALLA_ACTIVE_TILE_DIR=
VALHALLA_HOST_TILE_DIR=
VALHALLA_CONTAINER_NAME=road-context-valhalla
OSM_UPDATE_CRON=0 4 * * 0
TILE_PREFETCH_SCRIPT=scripts/prefetch-valhalla-bbox.sh
TILE_PREFETCH_TILE_ROOT=./data/valhalla-prefetch
TILE_PREFETCH_HOST_TILE_ROOT=
TILE_PREFETCH_OSM_PREFIX=prefetch
TILE_PREFETCH_HALF_LAT=0.010
TILE_PREFETCH_HALF_LON=0.010
TILE_PREFETCH_GRID_DEGREES=0.010
TILE_PREFETCH_LOOKAHEAD_CHUNKS=1
TILE_PREFETCH_LOOKAHEAD_METERS=800
TILE_PREFETCH_MIN_INTERVAL_SECONDS=60
TILE_PREFETCH_MAX_QUEUE=4
TILE_PREFETCH_CLEANUP_INTERVAL_SECONDS=3600
TILE_PREFETCH_RETENTION_HOURS=24
TILE_PREFETCH_MAX_STORED_CHUNKS=200
TILE_PREFETCH_RESTART_VALHALLA=true
TILE_PREFETCH_IMPORT_ALERTS=true
TILE_PREFETCH_MAX_AGE_HOURS=24
TILE_PREFETCH_RETRIES=2
TILE_PREFETCH_RETRY_DELAY_SECONDS=3
TILE_PREFETCH_LOCK_TIMEOUT_SECONDS=300
