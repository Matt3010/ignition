{
  "name": "motorcycle-road-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:drive": "ROAD_CONTEXT_PROVIDER=valhalla DRIVE_SOAK_REAL=true tsx scripts/drive-soak.ts",
    "test:drive:real": "ROAD_CONTEXT_PROVIDER=valhalla DRIVE_SOAK_REAL=true tsx scripts/drive-soak.ts",
    "test:drive:real:chunks": "bash scripts/drive-real-chunks.sh",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "tsx scripts/migrate.ts",
    "seed": "npm run import:osm-alerts",
    "import:alerts": "tsx scripts/import-alerts.ts",
    "import:osm-alerts": "tsx scripts/import-osm-alerts.ts",
    "alerts:purge-non-osm": "tsx scripts/purge-non-osm-alerts.ts",
    "valhalla:build": "bash scripts/build-valhalla-tiles.sh",
    "valhalla:prefetch": "bash scripts/prefetch-valhalla-bbox.sh",
    "valhalla:package": "bash scripts/package-valhalla-tiles.sh",
    "raspberry:smoke": "tsx scripts/raspberry-smoke.ts",
    "osm:download": "bash scripts/download-osm-extract.sh",
    "osm:bbox": "bash scripts/prepare-osm-bbox.sh",
    "osm:bbox:direct": "bash scripts/download-osm-bbox-direct.sh",
    "health": "tsx scripts/health.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
