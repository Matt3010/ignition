{
  "name": "motorcycle-road-assistant-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/src/server.js",
    "build": "tsc -p tsconfig.json",
    "test": "npm run test:deterministic",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "migrate": "node scripts/run-compiled.mjs migrate",
    "seed": "npm run import:osm-alerts",
    "import:osm-alerts": "node scripts/run-compiled.mjs import-osm-alerts",
    "alerts:ensure": "bash scripts/ensure-osm-alerts.sh",
    "valhalla:build": "bash scripts/build-valhalla-tiles.sh",
    "valhalla:package": "bash scripts/package-valhalla-tiles.sh",
    "raspberry:smoke": "node scripts/run-compiled.mjs raspberry-smoke",
    "osm:download": "bash scripts/download-osm-extract.sh",
    "osm:refresh": "bash scripts/refresh-osm.sh",
    "osm:refresh:loop": "bash scripts/osm-refresh-loop.sh",
    "health": "node scripts/run-compiled.mjs health",
    "test:deterministic": "vitest run tests/unit tests/integration",
    "test:postgis": "RUN_DB_INTEGRATION=1 vitest run tests/live/postgis-live.test.ts",
    "test:valhalla": "RUN_VALHALLA_INTEGRATION=1 vitest run tests/live/valhalla-live.test.ts",
    "test:full-stack": "RUN_FULL_STACK_INTEGRATION=1 vitest run tests/live/full-stack-live.test.ts",
    "test:real": "npm run test:postgis && npm run test:valhalla && npm run test:full-stack && npm run test:failures && npm run test:runtime && npm run test:network-faults",
    "verify:local": "npm run build && npm run lint && npm run test:deterministic",
    "verify:full": "npm run build && npm run lint && npm run test:deterministic && npm run test:real",
    "test:failures": "RUN_FAILURE_INTEGRATION=1 vitest run tests/live/service-failures-live.test.ts",
    "test:runtime": "RUN_RUNTIME_INTEGRATION=1 vitest run tests/live/runtime-live.test.ts",
    "test:network-faults": "RUN_NETWORK_FAULT_INTEGRATION=1 vitest run tests/live/valhalla-network-faults-live.test.ts",
    "test:tile-package": "npm run valhalla:package && bash scripts/verify-valhalla-package.sh",
    "test:osm-pipeline": "npm run osm:refresh"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/swagger": "^9.4.0",
    "@fastify/swagger-ui": "^5.2.0",
    "fastify": "^5.2.1",
    "pg": "^8.13.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.9"
  }
}
