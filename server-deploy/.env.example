# The workflow publishes this image automatically to GHCR.
# Replace owner/repository with your GitHub repository path.
IGNITION_IMAGE=ghcr.io/owner/repository:latest

OSM_REGIONS=italy
OSM_REFRESH_RUN_ON_START=false
OSM_REFRESH_INTERVAL_SECONDS=86400

PORT=3000
POSTGRES_PORT=5433
LOG_LEVEL=info
CORS_ORIGIN=*

# Multi-architecture PostGIS image suitable for ARM64 and AMD64 hosts.
POSTGIS_IMAGE=imresamu/postgis:16-3.4-bullseye

# Optional Valhalla override.
VALHALLA_DOCKER_IMAGE=ghcr.io/gis-ops/docker-valhalla/valhalla:3.5.1
