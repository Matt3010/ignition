# Ignition image published automatically by GitHub Actions.
IGNITION_IMAGE=ghcr.io/matt3010/ignition:latest

# Runtime
NODE_ENV=production
PORT=3000
LOG_LEVEL=info
CORS_ORIGIN=*

# PostgreSQL
POSTGRES_DB=road_context
POSTGRES_USER=road
# Use a long URL-safe password: letters, numbers, dash and underscore.
POSTGRES_PASSWORD=CHANGE_ME_WITH_A_LONG_RANDOM_PASSWORD
POSTGRES_PORT=5433
POSTGIS_IMAGE=imresamu/postgis:16-3.4-bullseye

# Backend and Valhalla timeouts
REQUEST_TIMEOUT_MS=5000
VALHALLA_TIMEOUT_MS=2500

# GPS validation
MAX_GPS_ACCURACY_METERS=50
MAX_SAMPLE_AGE_SECONDS=60
MAX_SAMPLE_FUTURE_SECONDS=5
SESSION_TRACE_TTL_SECONDS=180

# Alert selection
ALERT_SEARCH_RADIUS_METERS=1500
ALERT_BEHIND_MIN_ANGLE_DEGREES=135
ALERT_BEHIND_IMMEDIATE_ANGLE_DEGREES=170
ALERT_BEHIND_MIN_SPEED_KMH=5
ALERT_BEHIND_MAX_GPS_ACCURACY_METERS=25
ALERT_BEHIND_MIN_DISTANCE_INCREASE_METERS=5

# HTTP limits
PAYLOAD_LIMIT_BYTES=65536
RATE_LIMIT_MAX=180
RATE_LIMIT_WINDOW=1 minute
MIN_CLIENT_INTERVAL_MS=1000

# Application debug logs
APP_DEBUG_LOG_MAX_FILE_BYTES=5000000
APP_DEBUG_LOG_MAX_FILES=200
APP_DEBUG_LOG_RETENTION_DAYS=14

# OSM regions and refresh
# Supported presets include: italy,france,germany,spain,switzerland,austria,slovenia,croatia
OSM_REGIONS=italy
OSM_REFRESH_INTERVAL_SECONDS=432000
OSM_REFRESH_RUN_ON_START=false
OSM_REFRESH_LOCK_TIMEOUT_SECONDS=3600
OSM_REFRESH_LOCK_STALE_SECONDS=7200

# Protection against anomalous or incomplete OSM imports
OSM_IMPORT_MIN_RETAIN_RATIO=0.2
OSM_IMPORT_MIN_EXISTING_FOR_RATIO_CHECK=20

# Valhalla startup and health
VALHALLA_HEALTH_TIMEOUT_SECONDS=120
VALHALLA_HEALTH_INTERVAL_SECONDS=2
VALHALLA_DOCKER_IMAGE=ghcr.io/gis-ops/docker-valhalla/valhalla:3.5.1

# Optional staging path override. Leave unchanged for the standard deployment.

# Seconds between structured Valhalla build progress events.
VALHALLA_BUILD_PROGRESS_INTERVAL_SECONDS=60
# Official timezone-boundary-builder release used for timezones.sqlite.
VALHALLA_TIMEZONE_RELEASE=2026b
# Set both only when using a custom archive.
# VALHALLA_TIMEZONE_ARCHIVE_URL=https://example.invalid/timezones-with-oceans.shapefile.zip
# VALHALLA_TIMEZONE_ARCHIVE_SHA256=<64-character-sha256>
